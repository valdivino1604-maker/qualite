
:root{--black:#070707;--gold:#b88418;--gold2:#d9a638;--cream:#f8f3ea;--muted:#6f665b;--line:#e6dccb;--white:#fff;--shadow:0 18px 50px rgba(0,0,0,.12)}*{box-sizing:border-box}body{margin:0;font-family:Inter,Arial,sans-serif;background:#fff;color:#1b1713;line-height:1.6}h1,h2,h3{font-family:Georgia,'Times New Roman',serif;line-height:1.15;margin:0 0 16px}h1{font-size:clamp(2.3rem,5vw,5rem)}h2{font-size:clamp(1.8rem,3vw,3rem)}h3{font-size:1.3rem}a{color:inherit;text-decoration:none}img{max-width:100%;display:block}.container{width:min(1180px,92%);margin:auto}.site-header{position:sticky;top:0;z-index:50;background:rgba(255,255,255,.92);backdrop-filter:blur(12px);border-bottom:1px solid var(--line)}.nav-wrapper{height:84px;display:flex;align-items:center;justify-content:space-between}.brand img{width:255px;max-height:65px;object-fit:contain}.main-nav{display:flex;align-items:center;gap:24px;font-weight:700;font-size:.85rem;text-transform:uppercase}.main-nav a:hover{color:var(--gold)}.btn{display:inline-flex;align-items:center;justify-content:center;background:linear-gradient(135deg,var(--gold),var(--gold2));color:#fff;padding:14px 22px;border-radius:4px;border:1px solid transparent;font-weight:800;text-transform:uppercase;letter-spacing:.04em;font-size:.82rem;box-shadow:0 10px 24px rgba(184,132,24,.22);cursor:pointer}.btn:hover{transform:translateY(-1px)}.btn-outline{background:transparent;color:var(--gold);border-color:var(--gold);box-shadow:none}.btn-small{padding:10px 15px;font-size:.75rem}.menu-toggle{display:none;background:none;border:0;width:44px}.menu-toggle span{display:block;height:2px;background:var(--black);margin:7px 0}.hero{padding:80px 0;background:linear-gradient(120deg,#fff 0%,var(--cream) 100%);position:relative;overflow:hidden}.hero:before{content:"";position:absolute;inset:0;background:url('../img/marca-dagua-qualite.png') no-repeat 55% 55%;background-size:70%;opacity:.18;pointer-events:none}.hero-grid{position:relative;display:grid;grid-template-columns:1fr 1.05fr;gap:48px;align-items:center}.hero-text strong{color:var(--gold)}.hero-text p{font-size:1.2rem;color:var(--muted);max-width:620px}.eyebrow{display:inline-block;color:var(--gold);font-weight:900;text-transform:uppercase;letter-spacing:.16em;font-size:.78rem;margin-bottom:15px}.hero-actions{display:flex;gap:14px;flex-wrap:wrap;margin-top:25px}.hero-card{background:#fff;padding:14px;border-radius:18px;box-shadow:var(--shadow)}.hero-card img{border-radius:14px}.dark{background:var(--black);color:#fff}.feature-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:0}.features article{padding:32px 24px;border-right:1px solid rgba(255,255,255,.16)}.features h3{color:var(--gold2)}.features p{color:#ddd}.section{padding:76px 0}.cream{background:var(--cream)}.section-title{text-align:center;max-width:760px;margin:0 auto 38px}.section-title span{color:var(--gold);font-weight:900;text-transform:uppercase;letter-spacing:.12em}.cards{display:grid;gap:24px}.cards.four{grid-template-columns:repeat(4,1fr)}.cards article,.service-card,.contact-card,.client-login,.client-panel{background:#fff;border:1px solid var(--line);border-radius:16px;padding:28px;box-shadow:0 10px 30px rgba(0,0,0,.05)}.service-card{transition:.2s}.service-card:hover{transform:translateY(-4px);box-shadow:var(--shadow)}.icon{width:44px;height:44px;display:grid;place-items:center;border:1px solid var(--gold);color:var(--gold);border-radius:12px;font-size:1.3rem;margin-bottom:12px}.link-gold{color:var(--gold);font-weight:800}.split{display:grid;grid-template-columns:.8fr 1.2fr;gap:40px;align-items:center}.split img{border-radius:18px;box-shadow:var(--shadow)}.page-hero{padding:86px 0;background:linear-gradient(135deg,var(--black),#222);color:#fff;position:relative;overflow:hidden}.page-hero:after{content:"";position:absolute;inset:0;background:url('../img/marca-dagua-qualite.png') no-repeat right center;background-size:50%;opacity:.18}.page-hero .container{position:relative;z-index:1}.page-hero p{max-width:720px;color:#eee;font-size:1.2rem}.text-page{max-width:900px}.mission-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin:30px 0}.mission-grid article{background:var(--cream);padding:24px;border-radius:14px}.filters{display:flex;gap:10px;margin-bottom:26px;flex-wrap:wrap}.filters button{border:1px solid var(--line);background:#fff;padding:10px 16px;border-radius:100px;cursor:pointer;font-weight:800}.filters .active{background:var(--gold);color:#fff}.project-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:26px}.project-card{border:1px solid var(--line);border-radius:18px;overflow:hidden;background:#fff;box-shadow:0 12px 35px rgba(0,0,0,.08)}.project-card img{height:245px;width:100%;object-fit:cover}.project-card div{padding:22px}.project-card span{color:var(--gold);font-weight:800;text-transform:uppercase;font-size:.75rem}.client-layout{display:grid;grid-template-columns:390px 1fr;gap:26px;align-items:start}.client-login label,.contact-form label{display:block;font-weight:800;margin-bottom:16px}.client-login input,.contact-form input,.contact-form textarea,.contact-form select{width:100%;margin-top:6px;border:1px solid var(--line);padding:13px;border-radius:8px;font:inherit}.hint{font-size:.9rem;color:var(--muted);background:var(--cream);padding:12px;border-radius:10px}.hidden{display:none!important}.panel-head{display:flex;align-items:center;justify-content:space-between;gap:20px}.panel-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin:20px 0}.panel-grid article{background:var(--cream);border-radius:12px;padding:18px}.doc-list{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}.doc-item{border:1px solid var(--line);border-radius:12px;padding:14px;display:flex;justify-content:space-between;gap:12px;align-items:center}.panel-two{display:grid;grid-template-columns:1fr 1fr;gap:25px;margin-top:25px}.contact-grid{display:grid;grid-template-columns:1.2fr .8fr;gap:28px}.contact-form{background:#fff;border:1px solid var(--line);border-radius:16px;padding:28px}.contact-card img{width:260px;margin-bottom:15px}.map-placeholder{background:var(--cream);height:180px;border:1px dashed var(--gold);display:grid;place-items:center;border-radius:12px;color:var(--muted);margin-top:20px}.footer{background:#050505;color:#eee;padding-top:55px}.footer-grid{display:grid;grid-template-columns:1.4fr .8fr 1fr;gap:35px}.footer-logo{width:260px;background:#fff;border-radius:10px;padding:8px;margin-bottom:14px}.footer a{display:block;color:#eee;margin:8px 0}.footer h3{color:var(--gold2)}.copyright{text-align:center;border-top:1px solid rgba(255,255,255,.12);padding:20px;margin-top:35px;color:#bdbdbd}.float-whatsapp{position:fixed;right:22px;bottom:22px;background:#1fb65b;color:#fff;border-radius:999px;padding:14px 18px;box-shadow:var(--shadow);font-weight:900;z-index:60}.form-msg{font-weight:800;color:var(--gold)}
@media(max-width:950px){.menu-toggle{display:block}.main-nav{position:absolute;left:0;right:0;top:84px;background:#fff;display:none;flex-direction:column;align-items:flex-start;padding:22px 4%;border-bottom:1px solid var(--line)}.main-nav.open{display:flex}.hero-grid,.split,.client-layout,.contact-grid{grid-template-columns:1fr}.feature-grid,.cards.four,.project-grid,.mission-grid,.panel-grid,.doc-list,.panel-two,.footer-grid{grid-template-columns:1fr}.brand img{width:210px}.hero{padding:50px 0}.features article{border-right:0;border-bottom:1px solid rgba(255,255,255,.16)}}
